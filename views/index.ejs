<!DOCTYPE html>
<html>
<head>
  <title>Helpers System</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav>
    <h2>TaskConnect</h2>
    <div>
      <a href="/">Home</a>
      <a href="/my-subscriptions">My Subscriptions</a>
      <a href="/stats">Stats</a>
      <% if (user) { %>
        <a href="/dashboard">Dashboard</a>
        <a href="/logout">Logout</a>
      <% } else { %>
        <a href="/login">Login</a>
        <a href="/register">Register</a>
      <% } %>
    </div>
  </nav>

  <section class="hero">
    <h1>Volunteer and Create</h1>
    
    <% if (message) { %><p class="success"><%= message %></p><% } %>
  </section>

  <main class="grid">
    <% if (tasks.length === 0) { %>
      <p>No active tasks available right now.</p>
    <% } %>

    <% tasks.forEach(task => { %>
      <div class="card">
        <span class="pill">Active</span>
        <h3><%= task.title %></h3>
        <p><%= task.description %></p>
        <p><strong>Location:</strong> <%= task.location %></p>
        <p><strong>Owner:</strong> <%= task.owner ? task.owner.name : 'Unknown' %></p>

        <form action="/volunteer/<%= task._id %>" method="POST">
          <input type="text" name="identifier" placeholder="Email" required>
          <button type="submit">Volunteer</button>
        </form>
      </div>
    <% }) %>
  </main>
</body>
</html>
