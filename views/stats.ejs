<!DOCTYPE html>
<html>
<head><title>Stats</title><link rel="stylesheet" href="/style.css"></head>
<body>
<nav><h2>TaskConnect</h2><div><a href="/">Home</a><a href="/my-subscriptions">My Subscriptions</a><% if (user) { %><a href="/dashboard">Dashboard</a><% } else { %><a href="/login">Login</a><% } %></div></nav>
<main class="container">
  <h1>Active Task Volunteer Statistics</h1>
  <% if (stats.length === 0) { %><p>No active tasks.</p><% } %>
  <table>
    <thead><tr><th>Task</th><th>Location</th><th>Current Volunteers</th></tr></thead>
    <tbody>
      <% stats.forEach(row => { %>
        <tr><td><%= row.title %></td><td><%= row.location %></td><td><%= row.volunteerCount %></td></tr>
      <% }) %>
    </tbody>
  </table>
</main>
</body>
</html>
